APP_NAME=UNSAID Commerce API
ENVIRONMENT=local
DEBUG=true

# Database — use SQLite for local dev, PostgreSQL for production
DATABASE_URL=sqlite+aiosqlite:///./unsaid.db
# DATABASE_URL=postgresql+asyncpg://unsaid:password@localhost:5432/unsaid

CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# WhatsApp business number for order dispatch
WHATSAPP_BUSINESS_NUMBER=01005513291

# Groq AI API key (required for AI consultant and admin insights)
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Session security — MUST be changed in production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=replace_with_a_long_random_secret
SESSION_COOKIE_NAME=unsaid_session
SESSION_COOKIE_SECURE=false

# Admin bootstrap — creates first admin account on startup (one-time)
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=replace_with_a_strong_password

# Logging
LOG_FILE=logs/unsaid.log

# Security — enable HSTS in production behind HTTPS
ENABLE_HSTS=false
ENABLE_RATE_LIMIT=true

# Public site URL (used for sitemap, canonical URLs, OG tags)
SITE_URL=http://localhost:8000